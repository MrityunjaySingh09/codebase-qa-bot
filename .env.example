# ============================================================
# Codebase Q&A Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_PREFIX=codebase_

# --- LangSmith (Observability) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=codebase-qa-bot

# --- Git ---
# Optional: GitHub token for higher rate limits on public repos
GITHUB_TOKEN=

# --- Ingestion ---
REPOS_DIR=./data/repos
MAX_FILE_SIZE_KB=500          # Skip files larger than this
MAX_REPO_SIZE_MB=200          # Refuse repos larger than this

# --- Chunking ---
CHUNK_SIZE=800                # Max tokens per chunk (fallback)
CHUNK_OVERLAP=100             # Overlap tokens (fallback)

# --- Retrieval ---
VECTOR_TOP_K=20               # Candidates from vector search
BM25_TOP_K=20                 # Candidates from BM25 search
RERANK_TOP_K=5                # Final chunks after reranking

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
